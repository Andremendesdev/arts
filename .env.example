# ============================================================
# Supabase — https://supabase.com/dashboard/project/mgvfturdwdhlfspjspxd/settings/api-keys
# ============================================================

# URL do projeto
NEXT_PUBLIC_SUPABASE_URL=https://mgvfturdwdhlfspjspxd.supabase.co

# RECOMENDADO: Legacy anon key (aba "Legacy API Keys", começa com eyJ...)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Alternativa: publishable key (aba "API Keys", sb_publishable_...)
# Só use se estiver ativa no projeto — se der "Invalid API key", use a anon acima.
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# ============================================================
# Admin único
# ============================================================

# Mesmo e-mail do usuário criado em Authentication → Users
ADMIN_EMAIL=

# Opcional — só para: pnpm create-admin
# ADMIN_PASSWORD=
# SUPABASE_SERVICE_ROLE_KEY=
